<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDisplayName</key>
    <string>GitChop</string>
    <key>CFBundleExecutable</key>
    <string>GitChop</string>
    <key>CFBundleIdentifier</key>
    <string>com.bendansby.GitChop</string>
    <key>CFBundleName</key>
    <string>GitChop</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleVersion</key>
    <string>1.0.0</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.developer-tools</string>

    <!-- Sparkle update feed -->
    <key>SUFeedURL</key>
    <string>https://bendansby.com/apps/gitchop/appcast.xml</string>
    <!-- Shared EdDSA public key across this workspace's apps. The matching
         private key lives in the macOS Keychain under https://sparkle-project.org;
         losing that key orphans every shipped install from updates. -->
    <key>SUPublicEDKey</key>
    <string>nBzSfv0fqmlzU1CIIs0vlIReBFKdnGdWMHWqXt3z/Jo=</string>
    <key>SUEnableAutomaticChecks</key>
    <true/>
    <key>SUScheduledCheckInterval</key>
    <integer>86400</integer>
</dict>
</plist>
